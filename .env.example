# PostgreSQL connection used by Drizzle, app data, and auth storage
DATABASE_URL=postgres://postgres:postgres@localhost:5432/letsgo

# Secret used by Better Auth to sign/encrypt auth data
BETTER_AUTH_SECRET=

# Base URL used by Better Auth callbacks/cookies in local development
BETTER_AUTH_URL=http://localhost:3000

# Optional: reminder push notifications

# Secret required when calling the reminder push API endpoint
REMINDER_PUSH_SECRET=

# Public VAPID key sent to browsers for push subscription
VAPID_PUBLIC_KEY=

# Private VAPID JWK JSON used server-side to sign push messages
VAPID_PRIVATE_KEY=

# Contact email/URL sent to push services with VAPID requests
VAPID_SUBJECT=mailto:admin@letsgo.local
